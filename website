<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bio | @YourName</title>
    <style>
        body, html { margin: 0; padding: 0; height: 100%; overflow: hidden; font-family: 'Inter', sans-serif; background: #000; color: white; }

        /* Background Video */
        #bg-video {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1; object-fit: cover; filter: brightness(0.35);
        }

        /* Entrance Overlay */
        #overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.95);
            backdrop-filter: blur(25px); display: flex; justify-content: center;
            align-items: center; z-index: 100; cursor: pointer; transition: 1s ease;
        }

        /* Main Container */
        .container { display: flex; justify-content: center; align-items: center; height: 100vh; }

        /* Profile Card */
        .card {
            background: rgba(255, 255, 255, 0.04);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 40px; border-radius: 20px; text-align: center;
            width: 340px; box-shadow: 0 15px 40px rgba(0,0,0,0.6);
            animation: fadeIn 1.5s ease;
        }

        /* Profile Image with "Online" Glow */
        .pfp-container { position: relative; width: 100px; margin: 0 auto 15px; }
        .pfp { width: 100px; height: 100px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.2); object-fit: cover; }
        .status-dot {
            position: absolute; bottom: 5px; right: 5px;
            width: 18px; height: 18px; background: #43b581; /* Discord Green */
            border-radius: 50%; border: 3px solid #1a1a1a;
            box-shadow: 0 0 10px #43b581;
        }

        h1 { margin: 10px 0 5px; letter-spacing: 2px; font-size: 1.8rem; }
        .bio { opacity: 0.5; font-size: 0.9rem; margin-bottom: 25px; }

        /* Buttons */
        .links { display: flex; flex-direction: column; gap: 10px; }
        .btn {
            background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
            color: white; text-decoration: none; padding: 12px; border-radius: 10px;
            transition: 0.3s ease; font-weight: 500;
        }
        .btn:hover { background: #fff; color: #000; transform: translateY(-3px); box-shadow: 0 5px 15px rgba(255,255,255,0.2); }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <div id="overlay" onclick="startPage()"> [ CLICK TO ENTER ] </div>

    <video autoplay muted loop playsinline id="bg-video">
        <source src="mai.mp4" type="video/mp4">
    </video>

    <audio id="bg-music" loop>
        <source src="mai.mp3" type="audio/mpeg">
    </audio>

    <div class="container">
        <div class="card">
            <div class="pfp-container">
                <img src="your_pfp.png" class="pfp" alt="pfp">
                <div class="status-dot"></div>
            </div>
            <h1>YOUR NAME</h1>
            <p class="bio">developer • student • gamer</p>
            
            <div class="links">
                <a href="https://discord.com" class="btn">Discord</a>
                <a href="https://instagram.com" class="btn">Instagram</a>
                <a href="https://github.com" class="btn">GitHub</a>
            </div>
        </div>
    </div>

    <script>
        function startPage() {
            const music = document.getElementById('bg-music');
            music.volume = 0.4;
            music.play();
            
            const overlay = document.getElementById('overlay');
            overlay.style.opacity = '0';
            setTimeout(() => { overlay.style.display = 'none'; }, 1000);
        }
    </script>
</body>
</html>
